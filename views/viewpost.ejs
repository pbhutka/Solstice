<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solstice</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = { darkMode: 'class' };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="bg-slate-900 text-slate-100">

  <!-- Navbar -->
  <nav class="bg-slate-800 border-b border-slate-700 shadow-sm sticky top-0 z-20">
    <div class="w-full px-4 sm:px-6 lg:px-8">
      <div class="flex justify-around items-center h-16">
        <h1 class="text-2xl font-bold mr-auto text-blue-400"><a href="/posts/homepage">Solstice</a></h1>
        <div class="flex items-center gap-4">
          <a href="/user/logout" title="Logout" class="text-slate-300 hover:text-red-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>
          <a href="/user/myprofile" title="My Profile">
            <img src="/images/uploads/<%= user.profilepic %>" alt="My Profile"
              class="w-10 h-10 rounded-full object-cover border-2 border-transparent hover:border-blue-400 transition-all" />
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main -->
  <main class="max-w-7xl mx-auto py-8 px-4">
    <div class="mb-4 flex items-center gap-6">
      <a href="/posts/homepage" class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-200 transition-colors font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd"
            d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
            clip-rule="evenodd" />
        </svg>
        Back to Feed
      </a>
      <% if(user._id.toString() === self._id.toString()) { %>
      <a href="/posts/editpost/<%= post._id %>" class="inline-flex items-center gap-2 text-slate-400 hover:text-blue-400 transition-colors font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path
            d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z" />
          <path fill-rule="evenodd"
            d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"
            clip-rule="evenodd" />
        </svg>
        Edit Post
      </a>
      <% } %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

      <!-- Post Image -->
      <div class="lg:col-span-3 bg-slate-800 border border-slate-700 p-4 rounded-2xl shadow-md">
        <div class="bg-slate-700 rounded-xl flex justify-center items-center">
          <% if (post.image) { %>
          <img src="/images/uploads/<%= post.image %>" alt="Post Image"
            class="object-contain max-h-[75vh] w-full rounded-lg" />
          <% } else { %>
          <div class="flex flex-col items-center justify-center p-8 text-slate-400 h-96">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 mb-4" fill="none" viewBox="0 0 24 24"
              stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14" />
            </svg>
            <span>No Image</span>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Post Details -->
      <div class="lg:col-span-2">
        <div class="bg-slate-800 border border-slate-700 p-6 rounded-2xl shadow-md">
          <div class="flex items-center gap-4 mb-6">
            <a href="/user/profile/<%= post._id %>">
              <img src="/images/uploads/<%= user.profilepic %>" alt="Owner"
                class="w-14 h-14 rounded-full object-cover ring-2 ring-offset-2 ring-blue-500 ring-offset-slate-900" />
            </a>
            <div>
              <a href="/user/profile/<%= user._id %>"
                class="font-bold text-lg text-slate-100 hover:text-blue-400 transition-colors">
                <%= user.fullname %>
              </a>
              <p class="text-sm text-slate-500"><%= post.time %></p>
            </div>
          </div>

          <div class="space-y-4">
            <h1 class="text-3xl font-bold text-slate-100 leading-tight"><%= post.title %></h1>
            <p class="text-slate-300 whitespace-pre-wrap text-base leading-relaxed"><%= post.caption %></p>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
