<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Solstice</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = { darkMode: 'class' }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>

<body class="bg-slate-900 text-slate-100">

  <% if(typeof message !== 'undefined' && message.length > 0) { %>
  <div id="toast"
    class="fixed bottom-5 right-5 flex items-center w-full max-w-xs p-4 space-x-4 text-white bg-blue-600 rounded-lg shadow-lg opacity-0 transform translate-y-full duration-500"
    role="alert">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <div class="font-medium"><%= message %></div>
  </div>
  <% } %>

  <!-- Navbar -->
  <nav class="bg-slate-800 border-b border-slate-700 shadow-sm sticky top-0 z-20">
    <div class="w-full px-4 sm:px-6 lg:px-8">
      <div class="flex justify-around items-center h-16">
        <h1 class="text-2xl font-bold mr-auto text-blue-500"><a href="/posts/homepage">Solstice</a></h1>
        <div class="flex items-center gap-4">
          <a href="/posts/addpost" title="Add Post" class="text-slate-300 hover:text-blue-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24"
              stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </a>

          <a href="/user/myposts" title="My Posts" class="text-slate-300 hover:text-blue-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24"
              stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2H5a2 2 0 00-2 2v2m14 0h-2m-2 0h-2" />
            </svg>
          </a>

          <a href="/user/logout" title="Logout" class="text-slate-300 hover:text-red-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24"
              stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </a>

          <a href="/user/myprofile" title="My Profile">
            <img src="/images/uploads/<%= user.profilepic %>" alt="My Profile"
              class="w-10 h-10 rounded-full object-cover border-2 border-transparent hover:border-blue-500 transition-all" />
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main -->
  <main class="max-w-6xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="bg-slate-800 border border-slate-700 rounded-xl shadow-md overflow-hidden">
      <div class="flex flex-col md:flex-row">

        <!-- Sidebar -->
        <aside class="w-full md:w-1/4 p-6 border-b md:border-b-0 md:border-r border-slate-700">
          <h2 class="text-lg font-bold text-slate-100 mb-4">Settings</h2>
          <nav class="flex flex-row md:flex-col gap-2">
            <button data-target="edit-profile"
              class="setting-btn text-left w-full p-3 rounded-lg bg-blue-900 text-blue-300 font-semibold">Edit
              Profile</button>
            <button data-target="change-password"
              class="setting-btn text-left w-full p-3 rounded-lg hover:bg-slate-700 font-medium text-slate-300">Change
              Password</button>
            <button data-target="delete-account"
              class="setting-btn text-left w-full p-3 rounded-lg hover:bg-red-900 font-medium text-red-400">Delete
              Account</button>
          </nav>
        </aside>

        <!-- Content -->
        <div class="w-full md:w-3/4 p-8 space-y-12">

          <!-- Edit Profile -->
          <section id="edit-profile" class="content-panel space-y-8">
            <div>
              <h3 class="text-2xl font-bold text-slate-100">Public Profile</h3>
              <p class="text-slate-400 mt-1">This information will be displayed publicly.</p>
            </div>

            <div class="flex flex-col sm:flex-row items-start gap-8">
              <div class="flex-shrink-0">
                <img id="profile-pic-preview" src="/images/uploads/<%= user.profilepic %>"
                  class="w-32 h-32 rounded-full object-cover border-4 border-slate-700">
              </div>
              <form action="/user/changeprofilepic" method="post" enctype="multipart/form-data" class="flex-grow">
                <input autocomplete="off" type="file" name="profileImage" id="profileImage" accept="image/*"
                  class="text-slate-300 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-blue-700 file:text-white hover:file:bg-blue-600">
                <p class="text-sm text-slate-500 mt-3">Recommended: 400x400px, JPG/PNG/GIF.</p>
                <div class="mt-4 flex gap-2">
                  <button type="submit"
                    class="bg-blue-600 text-white px-4 py-2 text-sm rounded-md font-semibold hover:bg-blue-700">Save
                    Picture</button>
                  <a href="/user/removeprofilepic"
                    class="bg-slate-700 text-slate-200 px-4 py-2 text-sm rounded-md font-semibold hover:bg-slate-600">Remove</a>
                </div>
              </form>
            </div>

            <form action="/user/updateprofile" method="POST"
              class="space-y-4 border-t border-slate-700 pt-6">
              <div>
                <label for="fullname" class="block text-sm font-medium text-slate-300">Full Name</label>
                <input autocomplete="off" type="text" id="fullname" name="fullname" placeholder="<%= user.fullname %>"
                  class="mt-1 block w-full px-4 py-2 border border-slate-600 bg-slate-900 rounded-md text-slate-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              </div>
              <div>
                <label for="username" class="block text-sm font-medium text-slate-300">Username</label>
                <input autocomplete="off" type="text" id="username" name="username" placeholder="<%= user.username %>"
                  class="mt-1 block w-full px-4 py-2 border border-slate-600 bg-slate-900 rounded-md text-slate-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              </div>
              <div>
                <label for="bio" class="block text-sm font-medium text-slate-300">Bio</label>
                <textarea id="bio" name="bio" rows="3"
                  placeholder="<%= user.bio || 'Tell us a little about yourself' %>"
                  class="mt-1 block w-full px-4 py-2 resize-none border border-slate-600 bg-slate-900 rounded-md text-slate-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent"></textarea>
              </div>
              <div>
                <label for="gender" class="block text-sm font-medium text-slate-300">Gender</label>
                <select id="gender" name="gender"
                  class="mt-1 block w-full px-4 py-2 border border-slate-600 bg-slate-900 rounded-md text-slate-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                  <option value="">Select your gender</option>
                  <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Male</option>
                  <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
                  <option value="other" <%= user.gender === 'other' ? 'selected' : '' %>>Other</option>
                </select>
              </div>

              <div class="flex items-center gap-4 pt-2">
                <a href="/posts/homepage"
                  class="text-sm font-medium text-slate-400 hover:text-blue-400 transition-colors inline-flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                  </svg>
                  Go Back
                </a>
                <button type="submit"
                  class="bg-blue-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">Save
                  Profile</button>
              </div>
            </form>
          </section>

          <!-- Change Password -->
          <section id="change-password" class="content-panel hidden space-y-6">
            <div>
              <h3 class="text-2xl font-bold text-slate-100">Change Password</h3>
              <p class="text-slate-400 mt-1">Choose a strong, new password.</p>
            </div>
            <form action="/user/changepassword" method="post" class="space-y-4 max-w-md">
              <div>
                <label for="currentPassword" class="block text-sm font-medium text-slate-300">Current Password</label>
                <input autocomplete="off" type="text" name="currentPassword" id="currentPassword"
                  class="mt-1 block w-full px-4 py-2 border border-slate-600 bg-slate-900 rounded-md text-slate-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              </div>
              <div>
                <label for="newPassword" class="block text-sm font-medium text-slate-300">New Password</label>
                <input autocomplete="off" type="text" name="newPassword" id="newPassword"
                  class="mt-1 block w-full px-4 py-2 border border-slate-600 bg-slate-900 rounded-md text-slate-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              </div>
              <button type="submit"
                class="bg-blue-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-blue-700">Update
                Password</button>
            </form>
          </section>

          <!-- Delete Account -->
          <section id="delete-account" class="content-panel hidden space-y-6">
            <div>
              <h3 class="text-2xl font-bold text-red-500">Delete Account</h3>
              <p class="text-slate-400 mt-1">This action is permanent and cannot be undone.</p>
            </div>
            <form id="delete-form" action="/user/deleteuser" method="post"
              class="space-y-4 max-w-md bg-slate-900 border border-red-700 p-6 rounded-lg">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-300">Confirm Your Email</label>
                <input autocomplete="off" type="email" name="email" id="email" required placeholder="you@example.com"
                  class="mt-1 block w-full px-4 py-2 border border-slate-700 bg-slate-800 rounded-md text-slate-100 focus:ring-2 focus:ring-red-500 focus:border-transparent">
              </div>
              <div>
                <label for="password" class="block text-sm font-medium text-slate-300">Confirm Your Password</label>
                <input autocomplete="off" type="password" name="password" id="password" required
                  class="mt-1 block w-full px-4 py-2 border border-slate-700 bg-slate-800 rounded-md text-slate-100 focus:ring-2 focus:ring-red-500 focus:border-transparent">
              </div>
              <button type="submit"
                class="w-full bg-red-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-red-700">Delete My
                Account Permanently</button>
            </form>
          </section>

        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Toast
      const toast = document.getElementById('toast');
      if (toast) {
        setTimeout(() => {
          toast.classList.remove('opacity-0', 'translate-y-full');
          toast.classList.add('opacity-100', 'translate-y-0');
        }, 100);
        setTimeout(() => {
          toast.classList.remove('opacity-100', 'translate-y-0');
          toast.classList.add('opacity-0', 'translate-y-full');
          setTimeout(() => toast.remove(), 1000);
        }, 4000);
      }

      // Settings Tabs
      const settingButtons = document.querySelectorAll('.setting-btn');
      const contentPanels = document.querySelectorAll('.content-panel');
      settingButtons.forEach(button => {
        button.addEventListener('click', () => {
          const targetId = button.dataset.target;
          settingButtons.forEach(btn => {
            btn.classList.remove('bg-blue-900', 'text-blue-300', 'font-semibold');
            btn.classList.add('hover:bg-slate-700', 'font-medium', 'text-slate-300');
          });
          button.classList.add('bg-blue-900', 'text-blue-300', 'font-semibold');
          button.classList.remove('hover:bg-slate-700', 'font-medium', 'text-slate-300');
          contentPanels.forEach(panel => {
            if (panel.id === targetId) panel.classList.remove('hidden');
            else panel.classList.add('hidden');
          });
        });
      });
    });
  </script>
</body>
</html>
